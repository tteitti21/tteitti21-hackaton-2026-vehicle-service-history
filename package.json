{
  "name": "autohuolto-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first, stateless vehicle service-history analyzer.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
