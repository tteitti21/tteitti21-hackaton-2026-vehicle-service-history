{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MaintenanceResearch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "vehicle_variant",
    "components",
    "global_warnings",
    "researched_at"
  ],
  "properties": {
    "vehicle_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "make",
        "model",
        "generation",
        "model_year",
        "engine",
        "transmission",
        "market",
        "confidence",
        "unresolved_fields"
      ],
      "properties": {
        "make": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "generation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 160
        },
        "model_year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1886,
          "maximum": 3000
        },
        "engine": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 240
        },
        "transmission": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 240
        },
        "market": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 160
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unresolved_fields": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component_code",
          "component_label",
          "resolution",
          "interval_claims",
          "recommended_claim_id",
          "conflict_summary"
        ],
        "properties": {
          "component_code": {
            "type": "string"
          },
          "component_label": {
            "type": "string"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "resolved",
              "conflicting_sources",
              "insufficient_evidence"
            ]
          },
          "interval_claims": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "claim_id",
                "interval_km",
                "interval_months",
                "whichever_first",
                "conditions",
                "original_value",
                "original_unit",
                "source",
                "authority_rank",
                "compatibility",
                "compatibility_notes"
              ],
              "properties": {
                "claim_id": {
                  "type": "string"
                },
                "interval_km": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "interval_months": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "whichever_first": {
                  "type": "boolean"
                },
                "conditions": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "original_value": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "original_unit": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "enum": [
                    "km",
                    "mi",
                    "months",
                    "years",
                    "mixed",
                    null
                  ]
                },
                "source": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "title",
                    "publisher",
                    "url",
                    "retrieved_at",
                    "evidence"
                  ],
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "publisher": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "retrieved_at": {
                      "type": "string",
                      "format": "date"
                    },
                    "evidence": {
                      "type": "string"
                    }
                  }
                },
                "authority_rank": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 6
                },
                "compatibility": {
                  "type": "string",
                  "enum": [
                    "exact",
                    "strong",
                    "partial",
                    "weak",
                    "unknown"
                  ]
                },
                "compatibility_notes": {
                  "type": "string"
                }
              }
            }
          },
          "recommended_claim_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "conflict_summary": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "global_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "researched_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
